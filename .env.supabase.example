# SewaGo local/deployment configuration

# Server
NODE_ENV=development
PORT=4000
PUBLIC_APP_URL=http://localhost:4000
TRUST_PROXY=

# Storage
DATA_STORE=supabase
DATA_DIR=./data
ALLOW_JSON_DB_IN_PRODUCTION=

# Supabase runtime store. Required when DATA_STORE=supabase.
# Keep the service-role key server-side only. Never put it in public/*.js or mobile app config.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STATE_ID=default

# Admin
ADMIN_EMAIL=admin@sewago.app
ADMIN_PASSWORD=change-me-before-production

# Driver verification
# Demo code only. Replace with OTP/KYC before real onboarding.
DRIVER_LICENSE_DEMO_CODE=change-me-before-production
ALLOW_DEMO_VERIFICATION_IN_PRODUCTION=

# Account recovery and phone OTP
# Local default: sandbox. Production: use twilio or webhook.
OTP_PROVIDER=sandbox
OTP_SANDBOX_CODE=123456
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=
EMAIL_PROVIDER=sandbox
EMAIL_FROM=
EMAIL_PROVIDER_API_KEY=
ALLOW_SANDBOX_PROVIDERS_IN_PRODUCTION=

# Payments
# Current code supports sandbox only. Real provider verification must be wired before launch.
PAYMENT_PROVIDER=sandbox
PAYMENT_SANDBOX_PIN=1234

# Future real provider credentials
ESEWA_MERCHANT_ID=
ESEWA_SECRET=
ESEWA_SUCCESS_URL=
ESEWA_FAILURE_URL=
KHALTI_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

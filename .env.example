# SewaGo local/deployment configuration

# Server
NODE_ENV=development
PORT=4000
PUBLIC_APP_URL=http://localhost:4000
TRUST_PROXY=

# Geocoding (real address search + reverse geocode for GPS "use my location").
# Defaults to the free OpenStreetMap Nominatim host, which allows ~1 req/sec and
# requires a real PUBLIC_APP_URL in the User-Agent. For production traffic in
# Kathmandu, point this at a paid drop-in host (LocationIQ, Geoapify, MapTiler —
# same /search and /reverse API) so you are not rate-limited or blocked.
NOMINATIM_BASE=https://nominatim.openstreetmap.org

# Service area for GPS pins and address search.
#   kathmandu - only accept locations inside the Kathmandu valley (launch market).
#   global    - accept any coordinates, so the full ride/delivery flow can be
#               tested with real GPS from anywhere (e.g. while abroad).
# Default: global in development, kathmandu in production. Set SERVICE_AREA=global
# on a production deployment only for a deliberate remote pilot/test.
SERVICE_AREA=

# Native app downloads shown on /download (leave blank until you have built them).
# ANDROID_APK_URL is the public link to your EAS-built .apk (e.g. an Expo build URL or /public/sewago.apk).
ANDROID_APK_URL=
IOS_APP_STORE_URL=

# Storage. Options:
#   json          - local file (data/db.json). Single-node demo/pilot only.
#   supabase      - whole app state as one JSONB blob row. Simple, but every save
#                   re-uploads the entire state and it can't scale past a pilot.
#   supabase_rows - per-row store: each record is its own Postgres row, so a save
#                   writes only what changed. Recommended for real traffic.
#                   On first boot it auto-imports an existing `supabase` blob, so
#                   switching from supabase -> supabase_rows is just this flag
#                   (after running docs/supabase-schema.sql to create app_records).
DATA_STORE=json
DATA_DIR=./data
ALLOW_JSON_DB_IN_PRODUCTION=

# Supabase runtime store. Required when DATA_STORE=supabase or supabase_rows.
# Keep the service-role key server-side only. Never put it in public/*.js or mobile app config.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STATE_ID=default

# Admin
ADMIN_EMAIL=admin@sewago.app
ADMIN_PASSWORD=change-me-before-production

# Driver verification
# Demo code only. Replace with a real KYC/license provider before public launch.
DRIVER_LICENSE_DEMO_CODE=change-me-before-production
ALLOW_DEMO_VERIFICATION_IN_PRODUCTION=

# Phone OTP
# Local default: sandbox. Production: set OTP_PROVIDER=twilio or OTP_PROVIDER=webhook.
OTP_PROVIDER=sandbox
OTP_SANDBOX_CODE=123456
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=

# Account recovery email (password-reset links).
# Local default: sandbox (the API response carries the token for testing).
# Production: EMAIL_PROVIDER=resend (api key from resend.com), sendgrid, or
# webhook (POSTs {to, from, subject, text, html} to EMAIL_WEBHOOK_URL).
EMAIL_PROVIDER=sandbox
EMAIL_FROM=no-reply@your-domain.example
EMAIL_PROVIDER_API_KEY=
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_TOKEN=
ALLOW_SANDBOX_PROVIDERS_IN_PRODUCTION=

# Signup credit. Defaults to 5000 in development (instant demo) and 0 in
# production — every rupee of it is spendable on rides that pay real drivers,
# so only set it when running a deliberate, budgeted promotion.
WELCOME_BONUS=

# Platform pricing (rupees; all optional — sensible defaults apply).
# RIDE_SERVICE_FEE   - added to wallet ride bookings (default 5; cash rides exempt)
# FOOD_SERVICE_FEE   - added to every food order (default 15)
# RIDE_CANCEL_FEE    - charged when a wallet ride is cancelled after a real
#                      driver accepted; half compensates that driver (default 40)
# RIDE_SURGE_CAP     - max surge multiplier when riders outnumber online
#                      drivers (default 1.5, hard cap 3; sim rides never surge)
RIDE_SERVICE_FEE=5
FOOD_SERVICE_FEE=15
RIDE_CANCEL_FEE=40
RIDE_SURGE_CAP=1.5
# Distance-based food delivery (live orders): the restaurant's base fee covers
# the first FREE_KM of road distance, then PER_KM per extra km (extra capped
# at FOOD_DELIVERY_MAX_EXTRA). The courier earns 80% of the full fee.
FOOD_DELIVERY_FREE_KM=3
FOOD_DELIVERY_PER_KM=15
FOOD_DELIVERY_MAX_EXTRA=300

# Featured (promoted) listings: what a partner pays from their earnings
# balance to pin a live restaurant/hotel to the top of the customer list
# for 7 days. Repeat purchases stack.
PROMOTE_WEEK_PRICE=500

# Sequential ride dispatch: each ride is offered to one driver at a time
# (nearest pickup first). How long a driver holds the exclusive offer before
# it cascades to the next-nearest (5-60 seconds).
RIDE_OFFER_SECONDS=15

# Payments
# A top-up method goes LIVE automatically once its gateway keys are set below.
# Methods without keys fall back to the PIN-1234 sandbox in development and are
# hidden in production (unless ALLOW_SANDBOX_PROVIDERS_IN_PRODUCTION=true).
PAYMENT_SANDBOX_PIN=1234

# Khalti ePayment (KPG-2) — get keys at https://admin.khalti.com (live) or
# https://dev.khalti.com (test). KHALTI_MODE=test hits dev.khalti.com.
KHALTI_SECRET_KEY=
KHALTI_MODE=test

# eSewa ePay v2 — merchant/product code + HMAC secret from eSewa.
# Test credentials: product code EPAYTEST, secret 8gBm/:&EnhH.1/q (see developer.esewa.com.np).
# ESEWA_MODE=test hits rc-epay.esewa.com.np.
ESEWA_PRODUCT_CODE=
ESEWA_SECRET=
ESEWA_MODE=test
